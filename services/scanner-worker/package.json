{
    "name": "@protocol-atlas/scanner-worker",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "dependencies": {
        "@aave/core-v3": "^1.19.3",
        "@protocol-atlas/core": "workspace:*",
        "@protocol-atlas/db": "workspace:*",
        "dotenv": "^17.4.2",
        "viem": "^2.48.1",
        "zod": "^4.3.6"
    },
    "scripts": {
        "dev": "tsc -b ../../packages/core ../../packages/db && tsx watch src/index.ts",
        "scan:aave-watchlist": "tsc -b ../../packages/core ../../packages/db && tsx src/index.ts",
        "build": "tsc -b",
        "typecheck": "tsc -b --pretty false",
        "lint": "tsc -b --pretty false",
        "clean": "rm -rf dist *.tsbuildinfo"
    },
    "devDependencies": {
        "@types/node": "^25.6.0"
    }
}
