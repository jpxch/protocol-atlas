{
    "name": "@protocol-atlas/db",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "default": "./dist/src/index.js"
        }
    },
    "dependencies": {
        "@protocol-atlas/core": "workspace:*",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.20.0"
    },
    "scripts": {
        "build": "tsc -b",
        "typecheck": "tsc -b --pretty false",
        "lint": "tsc -b --pretty false",
        "clean": "rm -rf dist drizzle *.tsbuildinfo",
        "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
        "db:push": "drizzle-kit push --config=drizzle.config.ts"
    },
    "devDependencies": {
        "@types/pg": "^8.20.0",
        "drizzle-kit": "^0.31.10"
    }
}
